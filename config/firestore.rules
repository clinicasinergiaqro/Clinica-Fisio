rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isWriter() {
      return request.auth != null && request.auth.token.email in [
        'lftaranda@gmail.com',
        'gutierrezgarciazaray96@gmail.com',
        'camislerma26@gmail.com',
        'agoretti.mr@gmail.com',
        'dafnend26@gmail.com',
        'jriveare2000@hotmail.com'
      ];
    }
    function isSupervisor() {
      return request.auth != null &&
             request.auth.token.email == 'lftaranda@gmail.com';
    }
    function pacienteLiveUpdateOK() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['id','appSourceId','name','nombreNormalizado','dxLive',
                  'terapeutaActualLive','ultimaSesionLive','tieneAppLive',
                  'origenLive','pidMatchType','updatedAt',
                  // ── CAPA 3: set de fechas de todas las sesiones (arrayUnion) para que el
                  // dashboard vea el historial completo del histórico, no solo la última.
                  'fechasSesiones']);
    }
    function pacienteEjerciciosUpdateOK() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['ejercicios','ejerciciosToken','ejerciciosLinkActivo',
                  'reportesClinicosIA']);
    }
    function pacienteClinicoUpdateOK() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['name','dx','motivoConsulta','motivo','valoracion',
                  'dxFuncional','planTto','antecedentes','alergias',
                  'contraindicaciones','seguridadClinica',
                  'motivosAnteriores','motivoActualIndex','numSesionEpisodioActual',
                  'altaClinica','revaloraciones','consentimientos',
                  'consentimientoDatos','consentimientoImagen','consentimientoWhatsApp',
                  'estudiosDocs','fotos','docs',
                  // ── v12: campos de históricos (mig_pac_) que solo vivían en el iPad que
                  // los editó y no viajaban a Firestore (auditoría "todo en la nube" 🔴P2).
                  'sexo','eventosAdversos','revalSolicitada','etiquetas','historialCambios',
                  'telefono','fechaNacimiento','medicoReferente','age',
                  'fechaCreacion','fechaInicio',
                  // ── v12: _persistirDatosPaciente (LOOP E) escribe estos junto a name/age/telefono
                  // en un solo set(merge); sin ellos hasOnly rechaza TODO el write (permission-denied).
                  'nombreNormalizado','terapeuta',
                  // ── v14: rastro de recencia para detección de conflictos en históricos (LOOP B).
                  // updatedAt = serverTimestamp del último write clínico; ultimoUsuario/fechaActualizacion =
                  // quién y cuándo (legibles); ultimosCampos = qué campos escribió el último write — permite
                  // que el aviso de conflicto diga "X tocó [campos]" en vez de avisar a ciegas.
                  'updatedAt','ultimoUsuario','fechaActualizacion','ultimosCampos']);
    }
    function sesionCreateOK() {
      return request.resource.data.keys().hasOnly([
        'id','num','fecha','fechaHoraISO','semana','terapeuta',
        's','o','a','p','evaI','evaF','modalidades',
        'completa','modoNota','importado','formatoOriginal',
        'revisionPendiente','origen','creadoPor',
        'updatedAt','createdAt',
        'horaCreacion','totalSesiones','objetivoSesion','respuestaTratamiento',
        'tolerancia','eventosAdversosSesion','cambiosPlan','criteriosProgreso',
        'indicacionesDomiciliarias','dictado','dictadoUnico','dictadoV2',
        'pacienteId','media','historialEdiciones',
        'motivoIndex','numEpisodio',
        'atendidoPor'   // v12: quién atendió la sesión (no viajaba a subcolección de históricos)
      ]);
    }
    function sesionUpdateOK() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly([
          'num','fecha','fechaHoraISO','semana','terapeuta',
          's','o','a','p','evaI','evaF','modalidades',
          'completa','modoNota','revisionPendiente',
          'updatedAt','historialEdiciones',
          'objetivoSesion','respuestaTratamiento','tolerancia',
          'eventosAdversosSesion','cambiosPlan','criteriosProgreso',
          'indicacionesDomiciliarias','dictado','dictadoUnico','dictadoV2',
          'media','motivoIndex','numEpisodio',
          'terapeutaEstado','terapeutaOriginal','motivosRevision',
          'imagenesPendientes','motivoImagenesPendientes','hashesImagenesPendientes',
          'textoOriginal','textoOriginalUrl',
          'atendidoPor'   // v12: quién atendió la sesión (edición de nota histórica)
        ]);
    }
    // ── v8: asignaciones persistentes de agenda (LOOP S3) ──
    // Doc id = nombre normalizado del calendario. Solo el supervisor asigna;
    // todas las terapeutas pueden leer el mapa (lo usan pendientes y rendimiento).
    function asignacionAgendaOK() {
      return request.resource.data.keys().hasOnly([
        'nombreOriginal','terapeuta','asignadoPor','fechaAsignacion','updatedAt'
      ]);
    }
    // ── v9: citas resueltas a mano (dashboard triangulación V2) ──
    // Doc id = claveNorm + '__' + DD-MM-YYYY. Solo el supervisor resuelve;
    // todas las terapeutas pueden leer (el dashboard las descuenta de 🔴).
    function citaResueltaOK() {
      return request.resource.data.keys().hasOnly([
        'fecha','claveNorm','resueltoPor','updatedAt'
      ]);
    }
    // ── v13: vinculación permanente nombre-calendario → paciente (dashboard) ──
    // Doc id = claveNorm (nombreNormalizado del nombre del calendario). Solo el
    // supervisor vincula; todas las terapeutas leen (el resolver del dashboard la
    // aplica antes del match automático). Reversible: overwrite o delete del doc.
    function citaVinculadaOK() {
      return request.resource.data.keys().hasOnly([
        'pid','tipo','nombreOriginal','vinculadoPor','fecha','updatedAt'
      ]);
    }
    // ── BORRADO LÓGICO (papelera) ──
    // Poner/quitar el tombstone eliminado:true — SOLO isSupervisor() (= lftaranda@gmail.com,
    // punto ÚNICO de verdad del email en estas reglas). Whitelist estricta: SOLO los campos del
    // borrado/restauración; ningún otro campo puede cambiar en el mismo write (no abre un update amplio).
    // Cubre borrar (eliminado:true) y des-borrar (eliminado:false + restauradoPor/Fecha).
    function borradoKeysOK() {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(['eliminado','eliminadoPor','eliminadoFecha','restauradoPor','restauradoFecha']);
    }
    match /pacientes/{pacienteId} {
      allow read: if isWriter();
      allow create: if isWriter();
      allow update: if (isWriter() && (
                        pacienteLiveUpdateOK() ||
                        pacienteEjerciciosUpdateOK() ||
                        pacienteClinicoUpdateOK()
                      ))
                    || (isSupervisor() && borradoKeysOK());   // borrado/restauración: solo lftaranda
      allow delete: if isSupervisor();
    }
    match /pacientes/{pacienteId}/sesiones/{sesionId} {
      allow read: if isWriter();
      allow create: if isWriter() && sesionCreateOK();
      allow update: if (isWriter() && sesionUpdateOK())
                    || (isSupervisor() && borradoKeysOK());   // borrado/restauración de nota: solo lftaranda
      allow delete: if isSupervisor();
    }
    // Backup clínico completo del contenido borrado (doc + sesiones) — SOLO lftaranda.
    // Recursivo: cubre revision/{tipo}/{id}/{ts} y cualquier profundidad. Si falta, el backup
    // falla y el flujo de borrado NO marca el tombstone (orden estricto).
    match /revision/{document=**} {
      allow read, write: if isSupervisor();
    }
    // Papelera: índice de lo borrado para la vista de Papelera y la restauración. SOLO lftaranda.
    // Allowlist explícita por email vía isSupervisor() (NO "writer excepto cfag1092").
    match /papelera/{document=**} {
      allow read, create, delete: if isSupervisor();
    }
    match /agendaAsignaciones/{nombreNorm} {
      allow read: if isWriter();
      allow create, update: if isSupervisor() && asignacionAgendaOK();
      allow delete: if isSupervisor();
    }
    match /citasResueltas/{citaId} {
      allow read: if isWriter();
      allow create, update: if isSupervisor() && citaResueltaOK();
      allow delete: if isSupervisor();
    }
    match /citasVinculadas/{claveNorm} {
      allow read: if isWriter();
      allow create, update: if isSupervisor() && citaVinculadaOK();
      allow delete: if isSupervisor();
    }
    // ── v10: lectura por collection group de 'sesiones' (cola de revisión) ──
    // Habilita collectionGroup('sesiones').where(...) para writers. NO amplía la
    // audiencia: los writers ya pueden leer cada sesión por la ruta anidada de arriba.
    // Solo lectura — los writes siguen exclusivamente por la ruta anidada con whitelists.
    match /{path=**}/sesiones/{sesionId} {
      allow read: if isWriter();
    }
  }
}
